TZ=Etc/UTC
RGDASH_PORT=7805
# Number of successful upgrade backups to retain. 0 keeps every backup.
RGDASH_BACKUP_KEEP=0
# Optional: pin an exact release instead of following latest.
# RGDASH_IMAGE=ghcr.io/rogueassassin/rogue-dashboard:1.0.0
PUID=1000
PGID=1000
DOCKER_GID=999
DOCKER_AGENT_TOKEN=
SECURE_COOKIES=false
RGDASH_TRUST_PROXY_HEADERS=true
MEDIA_NETWORK=media-net
# Optional existing Docker network for services outside media-net.
# Example: application-network
RGDASH_EXTRA_NETWORK=
# Optional public link used when RogueRoute GPX containers are discovered.
RGDASH_ROGUEROUTE_URL=

# Optional comma-separated host allowlist. Leave empty for LAN access by IP.
# Example: localhost,127.0.0.1,rogue-dashboard,dash.example.com
RGDASH_ALLOWED_HOSTS=

# Service credentials remain outside the dashboard database.
# qBittorrent 5.2+ uses its qbt_ API key by default.
# Username/password remains an automatic fallback for older versions or a rejected key.
RGDASH_QBITTORRENT_API_KEY=
RGDASH_QBITTORRENT_USERNAME=
RGDASH_QBITTORRENT_PASSWORD=
RGDASH_PROWLARR_KEY=
RGDASH_RADARR_KEY=
RGDASH_SONARR_KEY=
RGDASH_SEERR_KEY=
RGDASH_BAZARR_KEY=
RGDASH_TAUTULLI_KEY=
RGDASH_PIHOLE_KEY=
