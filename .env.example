TZ=Australia/Melbourne
PUID=1000
PGID=1000
DOCKER_GID=999
DOCKER_AGENT_TOKEN=
SECURE_COOKIES=false
RGDASH_TRUST_PROXY_HEADERS=true

# Optional comma-separated host allowlist. Leave empty for LAN access by IP.
# Example: localhost,127.0.0.1,rogue-dashboard,dash.example.com
RGDASH_ALLOWED_HOSTS=

# Service credentials remain outside the dashboard database.
# qBittorrent's WebUI API uses its WebUI username/password and a session cookie.
RGDASH_QBITTORRENT_USERNAME=admin
RGDASH_QBITTORRENT_PASSWORD=
RGDASH_PROWLARR_KEY=
RGDASH_RADARR_KEY=
RGDASH_SONARR_KEY=
RGDASH_SEERR_KEY=
RGDASH_BAZARR_KEY=
RGDASH_TAUTULLI_KEY=
RGDASH_PIHOLE_KEY=
